{
  "name": "veritaschain",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm -r run lint --if-present",
    "test": "pnpm -r run test --if-present",
    "build": "pnpm -r run build --if-present",
    "dev": "pnpm -r run dev --if-present",
    "typecheck": "pnpm -r run typecheck --if-present",
    "services:offchain": "pnpm -C packages/services start"
  }
}
